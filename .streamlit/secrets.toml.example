# 이 파일을 `secrets.toml`로 복사해 실제 값을 채우세요(로컬 전용).
# 클라우드(Streamlit Community Cloud)에서는 이 내용을 앱 Settings → Secrets 에 붙여넣습니다.
# 값은 GCP 서비스 계정 JSON 키에서 그대로 옮깁니다.

[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# private_key는 줄바꿈을 \n 으로 둔 채 통째로 (따옴표 안에) 붙여넣습니다.
private_key = "-----BEGIN PRIVATE KEY-----\nMIIE...생략...\n-----END PRIVATE KEY-----\n"
client_email = "trading-journal-bot@your-project-id.iam.gserviceaccount.com"
client_id = "1234567890"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/trading-journal-bot%40your-project-id.iam.gserviceaccount.com"
